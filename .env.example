# ============================================
# Jolt Time - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# ============================================
# SUPABASE CONFIGURATION
# ============================================

# Supabase Project URL
# Found in: Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous (Public) Key
# Found in: Supabase Dashboard > Settings > API > Project API keys
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# SUPABASE BACKEND (Edge Functions)
# ============================================
# These are for Edge Functions only - NEVER expose to frontend
# ============================================

# Supabase Service Role Key
# Found in: Supabase Dashboard > Settings > API > Project API keys > service_role key
# Used by Edge Functions for admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Password (for CLI operations)
# Set during project creation
SUPABASE_DB_PASSWORD=your-db-password-here

# ============================================
# TELEGRAM CONFIGURATION
# ============================================

# Telegram Bot Token
# Get from: @BotFather after creating your bot
# Used for: WebApp initData validation, payments, bot commands
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Telegram Bot Username (for client-side display)
VITE_TELEGRAM_BOT_USERNAME=YourBotName

# Retention Bot Username (without @)
# The username of the bot that sends retention notifications
RETENTION_BOT_USERNAME=YourRetentionBot

# ============================================
# ADS INTEGRATION
# ============================================

# AdsGram Secret Key
# Get from: adsgram.app dashboard
# Used for: Validating rewarded ads
ADSGRAM_SECRET=your-adsgram-secret

# AdsGram Block ID (for client-side)
# This CAN be public - used in frontend
VITE_ADSGRAM_BLOCK_ID=your-adsgram-block-id

# ============================================
# VERTCAL DEPLOYMENT (Optional)
# ============================================

# Vercel Token
# Get from: Vercel Dashboard > Settings > Tokens
VERCEL_TOKEN=your-vercel-token

# Vercel Organization ID
VERCEL_ORG_ID=team_xxxxxxxxxxxxxx

# Vercel Project ID
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxx

# ============================================
# GITHUB ACTIONS (CI/CD)
# ============================================

# Supabase Project Reference
# Found in: Supabase Dashboard > Settings > General
SUPABASE_PROJECT_REF=your-project-ref

# ============================================
# SECURITY NOTES
# ============================================
#
# ⚠️ NEVER commit .env to version control!
# ⚠️ All secrets should be set via CI/CD or manual deployment
# ⚠️ Frontend variables MUST be prefixed with VITE_
# ⚠️ Backend-only variables should NOT be prefixed
#
# Required for production:
# - VITE_SUPABASE_URL
# - VITE_SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - SUPABASE_DB_PASSWORD
# - TELEGRAM_BOT_TOKEN
# - SUPABASE_PROJECT_REF
#
# Optional but recommended:
# - ADSGRAM_SECRET
# - VITE_ADSGRAM_BLOCK_ID
# - VERCEL_TOKEN (for CI/CD)
